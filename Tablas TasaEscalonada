CREATE TABLE FACTURA AS
SELECT 
    IdCredito,
    COUNT(FechaPagoFacturado) AS NumFac
FROM Factura
WHERE SUBSTR(IdCredito,1,2) IN ('83','91')
GROUP BY IdCredito;


