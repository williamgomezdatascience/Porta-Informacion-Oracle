EXCEPTION WHEN OTHERS THEN NULL;
END;
/

CREATE TABLE TEscalonada AS
SELECT ppv.IdCredito
       ,NumeroTramo1
       ,CodigoTasa1
       ,NumeroTramo2
       ,CodigoTasa2
FROM WS_Credito_PRD@BDPremierOriginacion wcr 
INNER JOIN WS_PlanPagosVehiculos@BDPremierOriginacion ppv 
    ON ppv.IdCredito = wcr.Consecutivo AND LENGTH(ppv.Exito) > 0
LEFT JOIN (SELECT Caso, PlanFinanciacion FROM Originacion@${Server}) Ori 
    ON Ori.Caso = wcr.Caso
LEFT JOIN (SELECT IdPlanFinanciacion, Valor FROM PlanFinanciacion@${Server}) PF 
    ON PF.IdPlanFinanciacion = Ori.PlanFinanciacion
WHERE PF.Valor LIKE '%ESCALONADA%'
  AND (LENGTH(wcr.Exito) > 0 OR wcr.Error = 'EL CREDITO YA EXISTE EN LA BASE')
  AND TRUNC(wcr.FechaProceso) >= DATE '2025-03-01';

CREATE INDEX TEscalonada_IX ON TEscalonada (IdCredito);
