BEGIN
  EXECUTE IMMEDIATE 'DROP TABLE SIIL02';
EXCEPTION WHEN OTHERS THEN NULL;
END;
/

CREATE TABLE SIIL02 (
    IdCredito  VARCHAR2(15),
    L02NPL     NUMBER,
    L02VPG     NUMBER
);

INSERT INTO SIIL02
SELECT 
    CAST(L02NPR AS NUMBER) AS IdCredito
    ,MAX(L02NPL) AS PlanPago
    ,NULL
FROM SIIF.SIIL02@BDPremierPrueba
INNER JOIN SolicitudCredito s ON s.id = CAST(L02NPR AS NUMBER) --41773
GROUP BY L02NPR;

-- Actualizacion de valor L02VPG
UPDATE SIIL02 S2
SET S2.L02VPG = (
    SELECT CASE WHEN CAST(REPLACE(sif2.L02VPG,'.00','') AS NUMBER) > 0 
                THEN CAST(REPLACE(sif2.L02VPG,'.00','') AS NUMBER) 
                ELSE 0 END
    FROM SIIF.SIIL02@BDPremierPrueba sif2
    WHERE CAST(sif2.L02NPR AS NUMBER) = S2.IdCredito
      AND sif2.L02NPL = 2
      AND ROWNUM = 1
)
WHERE EXISTS (
    SELECT 1 
    FROM SIIF.SIIL02@BDPremierPrueba sif2
    WHERE CAST(sif2.L02NPR AS NUMBER) = S2.IdCredito
      AND sif2.L02NPL = 2
);
